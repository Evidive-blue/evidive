// EviDive v2 - Prisma Schema Simplifié
// Neon Postgres

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ============================================
// 1. DIVER (Utilisateur = Plongeur ou Admin)
// ============================================
model Diver {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String?
  
  // Infos personnelles
  firstName    String?
  lastName     String?
  displayName  String?
  avatarUrl    String?
  bannerUrl    String?
  bio          String?
  phone        String?
  address      String?
  city         String?
  zip          String?
  country      String?

  // Rôle (DIVER ou ADMIN)
  role Role @default(DIVER)

  // Plongeur spécifique
  certificationLevel String?
  certificationOrg   String?
  totalDives         Int     @default(0)

  // Préférences
  preferredLanguage       String  @default("fr")
  emailNotifications      Boolean @default(true)
  smsNotifications        Boolean @default(false)
  timezone                String  @default("Europe/Paris")

  // Statut
  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?
  phoneVerified   Boolean   @default(false)
  isActive        Boolean   @default(true)
  isBlacklisted   Boolean   @default(false)

  // Verification tokens (inline for simplicity)
  verificationToken   String?
  verificationExpires DateTime?
  resetToken          String?
  resetExpires        DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  centers          Center[]      @relation("CenterOwner")
  bookings         Booking[]
  reviews          Review[]
  notifications    Notification[]
  moderatedReviews Review[]      @relation("ModeratedBy")

  @@map("divers")
}

enum Role {
  DIVER
  ADMIN
}

// ============================================
// 2. CENTER (Centre de plongée)
// ============================================
model Center {
  id      String @id @default(cuid())
  ownerId String
  slug    String @unique

  // Contenu multilingue (JSONB)
  name             Json // {fr: "", en: "", es: "", it: ""}
  description      Json
  shortDescription Json?

  // Localisation
  address   String
  street2   String?
  city      String
  region    String?
  country   String
  zip       String?
  latitude  Decimal
  longitude Decimal

  // Contact
  email     String
  phone     String
  website   String?
  facebook  String?
  instagram String?
  whatsapp  String?

  // Plongée
  certifications  String[] @default([])
  languagesSpoken String[] @default([])
  equipmentRental Boolean  @default(false)
  ecoCommitment   String?

  // Médias
  logoUrl       String?
  featuredImage String?
  photos        String[] @default([])
  
  // Icône pour la carte (diver, mask, fins, tank, anchor, wave)
  mapIcon       String?  @default("diver")

  // Paiement
  stripeAccountId String?
  paymentTypes    String[] @default([])
  iban            String?

  // Horaires (JSONB)
  openingHours Json?

  // Commission
  commissionRate Decimal @default(15)

  // Notifications (centre)
  emailOnNewBooking    Boolean @default(true)
  emailOnCancellation  Boolean @default(true)
  emailOnNewReview     Boolean @default(true)
  smsOnNewBooking      Boolean @default(false)
  dailyBookingReminder Boolean @default(false)

  // Politique d'annulation
  cancellationPolicy   CancellationPolicy @default(MODERATE)
  cancellationHours    Int                @default(48)
  partialRefundPercent Int                @default(50)

  // Statut
  status   CenterStatus @default(PENDING)
  featured Boolean      @default(false)
  verified Boolean      @default(false)

  // Stats
  rating       Decimal @default(0)
  reviewCount  Int     @default(0)
  bookingCount Int     @default(0)
  viewCount    Int     @default(0)

  // SEO
  seoTitle       Json?
  seoDescription Json?

  // Dates
  approvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  owner        Diver               @relation("CenterOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  services     Service[]
  workers      Worker[]
  bookings     Booking[]
  reviews      Review[]
  blockedDates CenterBlockedDate[]
  commissions  Commission[]
  waitingList  WaitingListEntry[]
  coupons      Coupon[]
  emailLogs    EmailLog[]
  smsLogs      SmsLog[]

  @@map("centers")
}

enum CenterStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum CancellationPolicy {
  FLEXIBLE
  MODERATE
  STRICT
}

// ============================================
// 3. SERVICE (Service de plongée)
// ============================================
model Service {
  id       String @id @default(cuid())
  centerId String

  // Contenu multilingue
  name        Json
  description Json?

  // Prix
  price          Decimal
  currency       String  @default("EUR")
  pricePerPerson Boolean @default(true)

  // Durée & Capacité
  durationMinutes Int
  minParticipants Int @default(1)
  maxParticipants Int @default(10)

  // Prérequis
  minCertification String?
  minAge           Int     @default(10)
  maxDepth         Int?

  // Inclus
  equipmentIncluded Boolean  @default(false)
  equipmentDetails  String?
  includes          String[] @default([])

  // Médias
  photos String[] @default([])

  // Disponibilité
  availableDays String[] @default(["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"])
  startTimes    String[] @default([])

  // Statut
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  center      Center             @relation(fields: [centerId], references: [id], onDelete: Cascade)
  extras      ServiceExtra[]
  bookings    Booking[]
  waitingList WaitingListEntry[]

  @@map("services")
}

// ============================================
// 4. SERVICE EXTRA (Options supplémentaires)
// ============================================
model ServiceExtra {
  id        String @id @default(cuid())
  serviceId String

  name          Json
  description   Json?
  price         Decimal
  multiplyByPax Boolean @default(false)
  isRequired    Boolean @default(false)
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())

  // Relations
  service       Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  bookingExtras BookingExtra[]

  @@map("service_extras")
}

// ============================================
// 5. WORKER (Équipe du centre)
// ============================================
model Worker {
  id       String @id @default(cuid())
  centerId String

  name           String
  email          String?
  phone          String?
  photoUrl       String?
  bio            String?
  certifications String[] @default([])
  languages      String[] @default([])

  // Horaires propres (JSONB)
  workingHours Json?

  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  center   Center    @relation(fields: [centerId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("workers")
}

// ============================================
// 6. BOOKING (Réservation)
// ============================================
model Booking {
  id        String @id @default(cuid())
  reference String @unique

  // Relations
  centerId  String
  serviceId String
  workerId  String?
  diverId   String?

  // Date & Heure
  diveDate        DateTime  @db.Date
  diveTime        DateTime  @db.Time()
  endTime         DateTime? @db.Time()
  durationMinutes Int?

  // Participants
  participants       Int   @default(1)
  participantDetails Json?

  // Client (si non connecté = guest)
  guestFirstName String?
  guestLastName  String?
  guestEmail     String
  guestPhone     String?
  guestAddress   String?

  // Demandes
  specialRequests    String?
  certificationLevel String?

  // Prix
  unitPrice      Decimal
  extrasPrice    Decimal @default(0)
  discountAmount Decimal @default(0)
  couponCode     String?
  totalPrice     Decimal
  currency       String  @default("EUR")
  depositAmount  Decimal @default(0)

  // Paiement
  paymentStatus           PaymentStatus @default(UNPAID)
  stripePaymentIntentId   String?
  stripeCheckoutSessionId String?
  paidAt                  DateTime?
  refundedAt              DateTime?
  refundAmount            Decimal?

  // Statut
  status             BookingStatus @default(PENDING)
  cancelledBy        CancelledBy?
  cancellationReason String?

  // Timestamps actions
  confirmedAt DateTime?
  cancelledAt DateTime?
  completedAt DateTime?

  // Tracking
  source    String  @default("website")
  ipAddress String?
  userAgent String?

  // Google Calendar
  gcalEventId String?
  gcalSynced  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  center        Center         @relation(fields: [centerId], references: [id])
  service       Service        @relation(fields: [serviceId], references: [id])
  worker        Worker?        @relation(fields: [workerId], references: [id])
  diver         Diver?         @relation(fields: [diverId], references: [id])
  extras        BookingExtra[]
  commission    Commission?
  couponUses    CouponUse[]
  emailLogs     EmailLog[]
  smsLogs       SmsLog[]
  notifications Notification[]
  review        Review?

  @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  PAID
  RUNNING
  COMPLETED
  CANCELLED
  NOSHOW
  REMOVED
}

enum PaymentStatus {
  UNPAID
  DEPOSIT_PAID
  PAID
  REFUNDED
  PARTIAL_REFUND
}

enum CancelledBy {
  CLIENT
  CENTER
  ADMIN
}

// ============================================
// 7. BOOKING EXTRA (Extras réservés)
// ============================================
model BookingExtra {
  id        String @id @default(cuid())
  bookingId String
  extraId   String

  quantity   Int     @default(1)
  unitPrice  Decimal
  totalPrice Decimal

  createdAt DateTime @default(now())

  // Relations
  booking Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  extra   ServiceExtra @relation(fields: [extraId], references: [id])

  @@map("booking_extras")
}

// ============================================
// 8. REVIEW (Avis)
// ============================================
model Review {
  id        String  @id @default(cuid())
  centerId  String
  diverId   String
  bookingId String? @unique

  // Contenu
  rating  Int
  title   String?
  comment String

  // Contexte
  diveDate    DateTime? @db.Date
  serviceUsed String?

  // Photos
  photos String[] @default([])

  // Modération
  status         ReviewStatus @default(PENDING)
  moderatedById  String?
  moderatedAt    DateTime?
  moderationNote String?

  // Réponse centre
  centerResponse   String?
  centerResponseAt DateTime?

  // Stats
  helpfulCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  center      Center  @relation(fields: [centerId], references: [id], onDelete: Cascade)
  diver       Diver   @relation(fields: [diverId], references: [id])
  booking     Booking? @relation(fields: [bookingId], references: [id])
  moderatedBy Diver?  @relation("ModeratedBy", fields: [moderatedById], references: [id])

  @@map("reviews")
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  SPAM
}

// ============================================
// 9. COUPON (Codes promo)
// ============================================
model Coupon {
  id          String  @id @default(cuid())
  code        String  @unique
  description String?

  // Type
  discountType  DiscountType
  discountValue Decimal

  // Restrictions
  centerId    String?
  serviceId   String?
  minAmount   Decimal?
  maxDiscount Decimal?

  // Validité
  validFrom      DateTime?
  validUntil     DateTime?
  maxUses        Int?
  usesCount      Int       @default(0)
  maxUsesPerUser Int       @default(1)

  // Options
  applyToExtras    Boolean @default(false)
  firstBookingOnly Boolean @default(false)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  // Relations
  center Center?     @relation(fields: [centerId], references: [id])
  uses   CouponUse[]

  @@map("coupons")
}

enum DiscountType {
  PERCENT
  FIXED
}

// ============================================
// 10. COUPON USE (Utilisations coupons)
// ============================================
model CouponUse {
  id              String   @id @default(cuid())
  couponId        String
  bookingId       String
  diverId         String?
  discountApplied Decimal
  createdAt       DateTime @default(now())

  // Relations
  coupon  Coupon  @relation(fields: [couponId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("coupon_uses")
}

// ============================================
// 11. COMMISSION (Suivi commissions)
// ============================================
model Commission {
  id        String @id @default(cuid())
  bookingId String @unique
  centerId  String

  bookingAmount    Decimal
  commissionRate   Decimal
  commissionAmount Decimal
  centerAmount     Decimal

  // Frais Stripe
  stripeFee  Decimal          @default(0)
  feesPaidBy FeesPaidBy       @default(WEBSITE)
  status     CommissionStatus @default(PENDING)
  paidAt     DateTime?

  createdAt DateTime @default(now())

  // Relations
  booking Booking @relation(fields: [bookingId], references: [id])
  center  Center  @relation(fields: [centerId], references: [id])

  @@map("commissions")
}

enum FeesPaidBy {
  WEBSITE
  CENTER
}

enum CommissionStatus {
  PENDING
  PAID
  CANCELLED
}

// ============================================
// 12. WAITING LIST (Liste d'attente)
// ============================================
model WaitingListEntry {
  id        String  @id @default(cuid())
  centerId  String
  serviceId String
  diverId   String?

  // Créneau souhaité
  desiredDate  DateTime @db.Date
  desiredTime  DateTime @db.Time()
  participants Int      @default(1)

  // Contact
  guestEmail String
  guestPhone String?
  guestName  String?

  // Statut
  status     WaitingListStatus @default(WAITING)
  notifiedAt DateTime?
  claimedAt  DateTime?
  expiresAt  DateTime?

  createdAt DateTime @default(now())

  // Relations
  center  Center  @relation(fields: [centerId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])

  @@map("waiting_list")
}

enum WaitingListStatus {
  WAITING
  NOTIFIED
  CLAIMED
  EXPIRED
  CANCELLED
}

// ============================================
// 13. CENTER BLOCKED DATE (Dates bloquées)
// ============================================
model CenterBlockedDate {
  id       String @id @default(cuid())
  centerId String

  blockedDate DateTime @db.Date
  reason      String?

  // Peut bloquer juste certains créneaux
  allDay       Boolean  @default(true)
  blockedTimes String[] @default([])

  createdAt DateTime @default(now())

  // Relations
  center Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@unique([centerId, blockedDate])
  @@map("center_blocked_dates")
}

// ============================================
// 14. NOTIFICATION (In-app)
// ============================================
model Notification {
  id      String @id @default(cuid())
  diverId String

  type    String
  title   String
  message String

  // Lien
  linkUrl  String?
  linkText String?

  // Relations
  bookingId String?
  centerId  String?
  reviewId  String?

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  // Relations
  diver   Diver    @relation(fields: [diverId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@map("notifications")
}

// ============================================
// 15. EMAIL LOG (Historique emails)
// ============================================
model EmailLog {
  id      String  @id @default(cuid())
  toEmail String
  toName  String?

  template String
  subject  String

  bookingId String?
  diverId   String?
  centerId  String?

  status       EmailStatus @default(SENT)
  errorMessage String?

  metadata Json?

  sentAt DateTime @default(now())

  // Relations
  booking Booking? @relation(fields: [bookingId], references: [id])
  center  Center?  @relation(fields: [centerId], references: [id])

  @@map("email_logs")
}

enum EmailStatus {
  SENT
  DELIVERED
  FAILED
  BOUNCED
}

// ============================================
// 16. SMS LOG (Historique SMS)
// ============================================
model SmsLog {
  id      String @id @default(cuid())
  toPhone String

  template String
  message  String

  bookingId String?
  diverId   String?
  centerId  String?

  status       SmsStatus @default(SENT)
  errorMessage String?
  twilioSid    String?

  sentAt DateTime @default(now())

  // Relations
  booking Booking? @relation(fields: [bookingId], references: [id])
  center  Center?  @relation(fields: [centerId], references: [id])

  @@map("sms_logs")
}

enum SmsStatus {
  SENT
  DELIVERED
  FAILED
}

// ============================================
// 17. PASSWORD RESET TOKEN
// ============================================
model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([token])
  @@map("password_reset_tokens")
}

// ============================================
// 18. EMAIL VERIFICATION TOKEN
// ============================================
model EmailVerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([token])
  @@map("email_verification_tokens")
}

// ============================================
// 19. SETTING (Configuration globale)
// ============================================
model Setting {
  key         String   @id
  value       Json
  description String?
  updatedAt   DateTime @default(now()) @updatedAt

  @@map("settings")
}
