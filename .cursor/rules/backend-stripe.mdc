### Refund Processing

```typescript
async function processRefund(bookingId: string, reason: string) {
  const booking = await prisma.booking.findUnique({
    where: { id: bookingId },
  })
  
  if (!booking?.stripePaymentIntentId) {
    throw new Error('No payment intent found')
  }
  
  const refund = await stripe!.refunds.create({
    payment_intent: booking.stripePaymentIntentId,
    reason: 'requested_by_customer',
    metadata: {
      bookingId,
      reason,
    },
  })
  
  await prisma.booking.update({
    where: { id: bookingId },
    data: {
      status: 'CANCELLED',
      paymentStatus: 'REFUNDED',
      refundedAt: new Date(),
      refundAmount: refund.amount / 100,
    },
  })
  
  return refund
}
```

## FORBIDDEN Patterns

### Wrong: Trusting client amount
```typescript
// WRONG - Client can modify amount!
const { amount } = await request.json()
await stripe.paymentIntents.create({ amount })

// CORRECT - Calculate on server
const service = await prisma.service.findUnique({ where: { id: serviceId } })
const amount = Number(service.price) * 100
await stripe.paymentIntents.create({ amount })
```

### Wrong: Skipping webhook verification
```typescript
// WRONG - No signature verification!
export async function POST(request: Request) {
  const event = await request.json()
  if (event.type === 'payment_intent.succeeded') {
    // Process payment...
  }
}

// CORRECT - Always verify signature
const event = stripe.webhooks.constructEvent(body, signature, webhookSecret)
```

### Wrong: Exposing secret key
```typescript
// WRONG - Client-side exposure
'use client'
const stripe = new Stripe(process.env.STRIPE_SECRET_KEY) // Exposed!

// CORRECT - Use Stripe.js on client
'use client'
import { loadStripe } from '@stripe/stripe-js'
const stripePromise = loadStripe(process.env.NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY!)
```

### Wrong: Logging sensitive data
```typescript
// WRONG
console.log('Card:', paymentMethod.card)

// CORRECT - Log only safe identifiers
console.log('PaymentMethod ID:', paymentMethod.id)
```

## Environment Variables

```env
# Server-side only
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Client-side (safe to expose)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
```

## Idempotency Keys

```typescript
// For retryable operations, use idempotency keys
const paymentIntent = await stripe.paymentIntents.create(
  {
    amount: 1000,
    currency: 'eur',
  },
  {
    idempotencyKey: `booking_${bookingId}_${Date.now()}`,
  }
)
```

