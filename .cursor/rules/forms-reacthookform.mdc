### Form with Server Action

```typescript
'use client'

import { useForm } from 'react-hook-form'
import { zodResolver } from '@hookform/resolvers/zod'
import { useActionState } from 'react'
import { createBooking } from '@/actions/bookings'

export function BookingForm({ serviceId }: { serviceId: string }) {
  const {
    register,
    handleSubmit,
    formState: { errors },
  } = useForm<BookingFormData>({
    resolver: zodResolver(bookingSchema),
  })

  const [state, formAction, isPending] = useActionState(createBooking, null)

  const onSubmit = (data: BookingFormData) => {
    const formData = new FormData()
    Object.entries(data).forEach(([key, value]) => {
      formData.append(key, String(value))
    })
    formData.append('serviceId', serviceId)
    formAction(formData)
  }

  return (
    <form onSubmit={handleSubmit(onSubmit)}>
      {/* Form fields */}
      
      {state?.error && (
        <div className="text-red-500">{state.error}</div>
      )}
      
      <button type="submit" disabled={isPending}>
        {isPending ? 'Booking...' : 'Book Now'}
      </button>
    </form>
  )
}
```

## FORBIDDEN Patterns

### Wrong: Using useState for form state
```typescript
// WRONG
const [email, setEmail] = useState('')
const [password, setPassword] = useState('')

<input value={email} onChange={(e) => setEmail(e.target.value)} />

// CORRECT
const { register } = useForm()

<input {...register('email')} />
```

### Wrong: Manual validation
```typescript
// WRONG
const handleSubmit = () => {
  if (!email.includes('@')) {
    setError('Invalid email')
    return
  }
}

// CORRECT
const { register, handleSubmit, formState: { errors } } = useForm({
  resolver: zodResolver(schema)
})
```

### Wrong: Ignoring errors
```typescript
// WRONG - No error display
<input {...register('email', { required: true })} />

// CORRECT - Show errors
<input {...register('email', { required: 'Email required' })} />
{errors.email && <span>{errors.email.message}</span>}
```

## Validation Modes

| Mode | Trigger | Use Case |
|------|---------|----------|
| `onSubmit` | On submit only | Default, simple forms |
| `onBlur` | On blur | Recommended for UX |
| `onChange` | On every change | Real-time validation |
| `onTouched` | On first blur, then onChange | Balanced approach |
| `all` | All triggers | Maximum feedback |

